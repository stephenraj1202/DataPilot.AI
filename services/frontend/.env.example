# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
# Create an OAuth 2.0 Client ID with:
#   - Authorized JavaScript origins: http://localhost:3000
#   - Authorized redirect URIs: http://localhost:3000
# Then copy the Client ID here:
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Service URLs — mirrors config.ini [services]
# Change these to domain URLs for production
VITE_FRONTEND_PORT=3000
VITE_API_GATEWAY_URL=http://localhost:8080
VITE_AUTH_SERVICE_URL=http://localhost:8081
VITE_BILLING_SERVICE_URL=http://localhost:8082
VITE_FINOPS_SERVICE_URL=http://localhost:8083
VITE_AI_QUERY_ENGINE_URL=http://localhost:8084
